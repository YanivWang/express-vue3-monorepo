{
  "name": "express-vue3-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "pnpm workspace：apps/backend/rest-api + apps/frontend（pc-portal / pc-admin）",
  "packageManager": "pnpm@10.17.0",
  "engines": {
    "node": ">=20.19.5",
    "pnpm": ">=10.17.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky",
    "dev": "pnpm -r --parallel run --if-present dev",
    "rest-api:dev": "pnpm --filter @express-vue3-monorepo/rest-api dev",
    "rest-api:dev:debug": "pnpm --filter @express-vue3-monorepo/rest-api dev:debug",
    "rest-api:start": "pnpm --filter @express-vue3-monorepo/rest-api start",
    "pc-portal:dev": "pnpm --filter @express-vue3-monorepo/pc-portal dev",
    "pc-admin:dev": "pnpm --filter @express-vue3-monorepo/pc-admin dev",
    "test": "pnpm --filter @express-vue3-monorepo/rest-api test",
    "test:all": "pnpm run test && playwright test",
    "typecheck": "pnpm -r --parallel run --if-present typecheck",
    "typecheck:solution": "tsc -b --pretty",
    "typecheck:packages": "pnpm -r --parallel --filter './packages/**' run --if-present typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:style": "stylelint '{apps/frontend,packages}/**/*.{css,scss,vue}'",
    "lint:style:fix": "stylelint '{apps/frontend,packages}/**/*.{css,scss,vue}' --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "pnpm run typecheck && pnpm run lint && pnpm run lint:style && pnpm run format:check && pnpm run test:all",
    "e2e": "playwright test",
    "e2e:docker": "playwright test",
    "e2e:local": "cross-env PLAYWRIGHT_LOCAL_SERVERS=1 playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install chromium",
    "docker:install": "cross-env APP_ENV=development docker compose --env-file .env.development -f docker/docker-compose.base.yaml -f docker/docker-compose.dev.yaml exec -e CI=true -T rest-api pnpm install --frozen-lockfile",
    "docker:pnpm": "cross-env APP_ENV=development docker compose --env-file .env.development -f docker/docker-compose.base.yaml -f docker/docker-compose.dev.yaml exec -e CI=true -T rest-api pnpm",
    "docker:dev:debug": "bash scripts/docker-dev.sh --debug",
    "docker:dev": "bash scripts/docker-dev.sh",
    "docker:dev:down": "cross-env APP_ENV=development docker compose --env-file .env.development -f docker/docker-compose.base.yaml -f docker/docker-compose.dev.yaml down",
    "docker:test": "cross-env APP_ENV=test docker compose --env-file .env.test -f docker/docker-compose.base.yaml -f docker/docker-compose.test.yaml up -d --build",
    "docker:prod": "cross-env APP_ENV=production docker compose --env-file .env.production -f docker/docker-compose.base.yaml -f docker/docker-compose.yaml up -d --build",
    "db:reset": "pnpm --filter @express-vue3-monorepo/rest-api db:reset",
    "db:dedupe-indexes": "pnpm --filter @express-vue3-monorepo/rest-api db:dedupe-indexes",
    "db:init-post": "pnpm --filter @express-vue3-monorepo/rest-api db:init-post"
  },
  "lint-staged": {
    "apps/backend/**/*.{ts,mts,cts}": "eslint --fix",
    "apps/frontend/**/*.{ts,vue,js,mjs}": "eslint --fix",
    "packages/**/*.{ts,vue,js,mjs}": "eslint --fix",
    "apps/frontend/**/*.{scss,vue,css}": "stylelint --fix",
    "packages/**/*.{scss,vue,css}": "stylelint --fix",
    "*.{json,md,yaml,yml,css,scss,vue,ts,js,mjs}": "prettier --write"
  },
  "devDependencies": {
    "@playwright/test": "catalog:",
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@eslint/js": "catalog:",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-import": "catalog:",
    "eslint-import-resolver-typescript": "catalog:",
    "eslint-plugin-vue": "catalog:",
    "globals": "catalog:",
    "husky": "catalog:",
    "lint-staged": "catalog:",
    "postcss-html": "catalog:",
    "prettier": "catalog:",
    "stylelint": "catalog:",
    "stylelint-config-html": "catalog:",
    "stylelint-config-recess-order": "catalog:",
    "stylelint-config-standard": "catalog:",
    "stylelint-config-standard-scss": "catalog:",
    "stylelint-order": "catalog:",
    "stylelint-prettier": "catalog:",
    "stylelint-scss": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vue-eslint-parser": "catalog:"
  },
  "dependencies": {
    "cross-env": "^10.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt"
    ]
  }
}
