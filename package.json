{
  "name": "express-demo-02",
  "version": "1.0.0",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "nodemon src/server.js",
    "dev:debug": "nodemon --inspect=0.0.0.0:9229 src/server.js",
    "docker:dev": "docker compose --env-file .env -f docker/docker-compose.dev.yaml up -d --build",
    "docker:install": "docker compose --env-file .env -f docker/docker-compose.dev.yaml exec -e CI=true -T app pnpm install --frozen-lockfile",
    "docker:pnpm": "docker compose --env-file .env -f docker/docker-compose.dev.yaml exec -e CI=true -T app pnpm",
    "docker:dev:debug": "docker compose --env-file .env -f docker/docker-compose.dev.yaml -f docker/docker-compose.debug.yaml up -d --build",
    "docker:prod": "docker compose --env-file .env -f docker/docker-compose.yaml up -d --build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "4.22.1",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.22.3",
    "sequelize": "^6.37.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  },
  "engines": {
    "node": ">=20.19.5",
    "pnpm": ">=10.17.0"
  },
  "packageManager": "pnpm@10.17.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt"
    ]
  }
}
