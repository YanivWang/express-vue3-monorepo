# -----------------------------------------------------------------------------
# 复制本文件为 .env.development / .env.production 等，或配合 docker --env-file 使用。
# 切勿将含真实密钥的 .env.* 提交到版本库。
# -----------------------------------------------------------------------------

# --- 运行环境 ---
# APP_ENV：决定加载根目录下哪份环境文件：先读 .env.${APP_ENV}，再读 .env.${APP_ENV}.local（后者可覆盖前者中未由进程注入的键）。
#         仅允许：development | test | production。
APP_ENV=development

# NODE_ENV：Node 标准运行环境标识。若与 APP_ENV 同时设置，二者必须一致，否则进程会退出。
NODE_ENV=development

# --- HTTP 与认证 ---
# JWT_SECRET：签发与校验 JWT 的对称密钥。至少 32 个字符；不得使用常见弱口令；生产环境不得保留 replace_with / change_me 等占位字样。
JWT_SECRET=replace_with_random_string_at_least_32_characters_long

# PORT：应用监听端口。本机直接 `pnpm rest-api:dev` 时使用；Compose 栈内因与 nginx upstream 对齐，通常固定为 3000（见 docker-compose.* 中 rest-api.environment.PORT）。
PORT=3000

# APP_HOST_PORT：（历史）曾用于将 rest-api 映射到宿主；网关统一入口模式下不再使用，可忽略。
# APP_HOST_PORT=3000

# GATEWAY_HOST_PORT：Compose 中网关 Nginx 暴露在宿主的端口（对内监听 2026），默认 2026。
# GATEWAY_HOST_PORT=2026

# NGINX_GATEWAY_CONF：（可选）挂载到网关的主配置文件名（相对 docker/nginx/），替换默认 gateway.dev.docker.conf / gateway.prod.docker.conf。
# NGINX_GATEWAY_CONF=gateway.dev.docker.conf

# --- 日志 ---
# LOG_LEVEL：应用日志级别（如 info、debug、warn、error）。未设置时默认为 info。
LOG_LEVEL=info

# --- 反向代理（Express trust proxy，src/app.js 读取 TRUST_PROXY）---
# 前面有 Nginx / Ingress / LB 时启用，便于 req.ip 等反映真实客户端；本机直连 node 可不设。
# 取值：1 或 true = 信任一层代理；正整数 = 信任的代理层数（如 2 = CDN + 一层网关）。
# TRUST_PROXY=1

# --- CORS（浏览器跨域，src/env.js：CORS_ORIGINS / getCorsOriginOption）---
# development / test 未设置 CORS_ORIGINS 时等价允许任意 Origin；production 未设置则关闭跨域。
# 白名单为英文逗号分隔的完整 Origin，例如：
# CORS_ORIGINS=https://app.example.com,https://admin.example.com

# --- MySQL（应用连接，由 src/env.js 校验）---
# DB_HOST：数据库主机。
# —— 推荐：通过 Compose 运行 rest-api；Compose 会为容器注入 DB_HOST=mysql（覆盖本文件中同名键），应用与 MySQL 均在容器网格内通信，宿主无需安装 MySQL。
# —— 仅在宿主本机执行 pnpm rest-api:dev 时：须填宿主可达地址（常见：先将 compose 中 mysql 映射 3306 到宿主，再使用 127.0.0.1）。
DB_HOST=127.0.0.1

# DB_PORT：MySQL 端口。未设置时默认为 3306。
DB_PORT=3306

# DB_NAME：应用使用的逻辑库名。
DB_NAME=express_demo_02

# DB_USER：应用连接使用的数据库用户（建议在库内单独创建并授权，避免使用 root）。
DB_USER=app_user

# DB_PWD：DB_USER 的密码。生产环境不得使用占位符。
DB_PWD=change_me_app_password

# --- Docker Compose 中的 MySQL 服务（docker/docker-compose.base.yaml）---
# MYSQL_ROOT_PASSWORD：仅用于 MySQL 容器内 root 账户及健康检查；应用业务连接应使用 DB_* 变量，而不是 root。
MYSQL_ROOT_PASSWORD=change_me_mysql_root_password
