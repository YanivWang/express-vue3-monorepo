# 复制为 .env 后按需修改。JWT_SECRET 需 ≥32 字符且不能是 env.js 中的弱密码列表。
#
# Compose 位于 docker/，开发与生产两份文件彼此独立（无 include、不需双 -f）。仓库根目录执行并传入本文件：
#   pnpm docker:up  — 仅 docker-compose.yaml：生产镜像，MySQL 不映射宿主机端口
#   pnpm docker:dev — 仅 docker-compose.dev.yaml：热重载 + bind mount，MySQL 映射 MYSQL_PORT；容器/数据卷名带 dev，与生产栈分离
# 若同时起两套，请为其中一套改 APP_PORT（及可选 MYSQL_PORT），避免宿主机端口冲突。
# 依赖变更后：对开发栈可 docker compose -f docker/docker-compose.dev.yaml build --no-cache app，或删除卷 app_node_modules 后再 up。
#
PORT=3000
JWT_SECRET=replace_with_random_string_at_least_32_characters_long

# 业务库（与 Sequelize 一致）
DB_NAME=express_demo
DB_USER=app_user
DB_PWD=app_password_change_me

# Docker Compose 下 app 会通过 environment 覆盖为 mysql；本地直连时改为 127.0.0.1
DB_HOST=mysql

# MySQL 容器 root（健康检查等使用）
MYSQL_ROOT_PASSWORD=root_password_change_me

# 可选：映射端口（compose 里引用；app 容器端口与 PORT 一致，宿主机端口为 APP_PORT）
APP_PORT=3000
MYSQL_PORT=3306
