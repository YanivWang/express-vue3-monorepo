{
  "name": "@express-vue3-monorepo/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "PC 端共享源码（类型、Token 存储、auth 会话、request-pc preset）；HTTP 与 apps/backend/rest-api 对齐；依赖 @express-vue3-monorepo/request-core",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "import": "./src/types/index.ts"
    },
    "./types/*": "./src/types/*",
    "./constants": {
      "types": "./src/constants/index.ts",
      "import": "./src/constants/index.ts"
    },
    "./constants/*": "./src/constants/*",
    "./utils": {
      "types": "./src/utils/index.ts",
      "import": "./src/utils/index.ts"
    },
    "./auth": {
      "types": "./src/auth/index.ts",
      "import": "./src/auth/index.ts"
    },
    "./auth/*": "./src/auth/*",
    "./request-pc": {
      "types": "./src/request-pc/index.ts",
      "import": "./src/request-pc/index.ts"
    },
    "./request-pc/*": "./src/request-pc/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@express-vue3-monorepo/request-core": "workspace:*",
    "js-cookie": "catalog:"
  },
  "peerDependencies": {
    "element-plus": "catalog:",
    "vue": "catalog:"
  },
  "peerDependenciesMeta": {
    "element-plus": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/js-cookie": "catalog:",
    "element-plus": "catalog:",
    "typescript": "catalog:",
    "vue": "catalog:"
  }
}
