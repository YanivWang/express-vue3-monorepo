{
  "extends": "../../tsconfig.pkg.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "outDir": "./node_modules/.tmp/tsc-decl",
    "rootDir": "./src",
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.build.tsbuildinfo",
    "types": []
  },
  "include": ["src/**/*.ts"]
}
