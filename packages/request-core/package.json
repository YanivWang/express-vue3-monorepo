{
  "name": "@express-vue3-monorepo/request-core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "UI-free HTTP client core（axios + 注入式 hooks）；默认响应形态对齐 apps/backend/rest-api `{ code, msg, ...payload }`",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "axios": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:"
  }
}
