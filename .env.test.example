# 复制为 .env.test。pnpm docker:test 或本地 NODE_ENV=test 时使用。
# 占位密码仅用于示例；不要用模板值连接真实生产库。

APP_ENV=test
NODE_ENV=test

JWT_SECRET=replace_with_random_string_at_least_32_characters_long

# 宿主与 Compose 端口占位（可多栈并行调度）
# MYSQL_HOST_PORT 仅开发栈 docker-compose.dev.yaml 映射 MySQL；生产/测试 Compose 不使用，保留键名便于跨环境对齐
PORT=3000
APP_HOST_PORT=3000
MYSQL_HOST_PORT=3306

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=express_demo_02
DB_USER=app_user
DB_PWD=app_password_change_me

MYSQL_ROOT_PASSWORD=root_password_change_me

# Winston 日志级别（可选，未设置时默认为 info）；见 src/utils/logger.js
LOG_LEVEL=info
