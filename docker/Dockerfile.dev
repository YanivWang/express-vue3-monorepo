FROM node:22-bookworm-slim

# bcrypt 等原生模块在 slim 镜像里可能需要本地编译（与生产 Dockerfile 一致）
RUN apt-get update && apt-get install -y --no-install-recommends python3 make g++ \
  && rm -rf /var/lib/apt/lists/*

# Install pnpm via npm mirror so build does not rely on Corepack fetching from registry.npmjs.org (often flaky behind certain networks).
ARG PNPM_VERSION=10.17.0
RUN npm config set registry https://registry.npmmirror.com \
  && npm install -g pnpm@${PNPM_VERSION}

WORKDIR /app

# 镜像内无 git：避免根目录 prepare（husky）在 pnpm install 阶段报错或无意义安装
ENV HUSKY=0

COPY pnpm-workspace.yaml package.json pnpm-lock.yaml ./
COPY .npmrc ./
COPY apps/backend/rest-api/package.json apps/backend/rest-api/
COPY apps/frontend/pc-portal/package.json apps/frontend/pc-portal/
COPY apps/frontend/pc-admin/package.json apps/frontend/pc-admin/
COPY packages/shared/package.json packages/shared/
COPY packages/request-core/package.json packages/request-core/
COPY packages/js-bridge/package.json packages/js-bridge/
COPY packages/web-monitor/package.json packages/web-monitor/
# pc-portal 的 @yanivjs/yaniv-editor 为 monorepo 外 file: 依赖，构建阶段不安装 pc-portal 子图（与 docker/Dockerfile 一致）
RUN pnpm install --frozen-lockfile --filter @express-vue3-monorepo/rest-api

ENV NODE_ENV=development
ENV PORT=3000

# rest-api（默认 3000）；pc-portal（5173）、pc-admin（5174）由 Compose 在网格内访问，经网关统一对外
EXPOSE 3000 5173 5174

CMD ["pnpm", "rest-api:dev"]
