# -----------------------------------------------------------------------------
# 合成 IT 帖子 / 种子脚本专用环境变量（可提交；密钥请留空或用 synthetic-it.env.local 覆盖）
#
# 合并顺序（见 synthetic-it-merge-monorepo-dotenv.ts）：
#   1) monorepo 根 `.env.${APP_ENV|NODE_ENV}` / `.env.*.local`（不覆盖进程已注入变量）
#   2) 本目录 `synthetic-it.env`、`synthetic-it.env.local`：仅 REST_API_* / SYNTHETIC_* /
#      DEDUPE_INDEXES* / ENSURE_SUPER_ADMIN_* 会写入 process.env，并覆盖根目录同名键
#
# 下列脚本内常量不从本文件读取（ESM 加载顺序）：externalSource、manifest 路径、HTTP UA — 见 synthetic-it-constants.ts
#
# 命令：
#   仓库根：pnpm db:init-post（或 pnpm --filter @vue3-express-monorepo/rest-api db:init-post）
#   或 cd apps/backend/rest-api && pnpm db:init-post
#   仅写示例类目：pnpm it:seed-categories（空表才写入；不写帖子）
#   仅清帖：pnpm synthetic-it:clear
#   仅去重索引：pnpm db:dedupe-indexes
#
# 默认「IT技术」两级类目由 pnpm it:seed-categories 或合成帖链写入；数据见 it-category-seed.json，
# 须与 synthetic-it-data.ts 各分类 categoryName 一致
# -----------------------------------------------------------------------------

# 索引去重：设为 1 或 true 时只打印将 DROP 的索引，不执行（db:init-post 第一步）
# DEDUPE_INDEXES_DRY_RUN=

REST_API_BASE=http://127.0.0.1:2026/api
REST_API_IMPORT_TOKEN=
REST_API_IMPORT_USERNAME=
REST_API_IMPORT_PASSWORD=

ENSURE_SUPER_ADMIN_USERNAME=root
ENSURE_SUPER_ADMIN_PASSWORD=123456

SYNTHETIC_RATE_MS=120
# SYNTHETIC_USE_STATIC_BUNDLE — 不设则按是否配置 SYNTHETIC_LLM_API_KEY 自动选择；1/true 或 0/false 可强制

SYNTHETIC_LLM_API_KEY=
SYNTHETIC_LLM_BASE_URL=https://api.openai.com/v1
SYNTHETIC_LLM_MODEL=gpt-4o-mini
# 不设则启用 response_format json_object；设为 0 可关闭（兼容部分网关）
# SYNTHETIC_LLM_JSON_OBJECT=
SYNTHETIC_LLM_MAX_TOKENS=4096
SYNTHETIC_LLM_TEMPERATURE=

# 不设时：有 Pexels Key 则默认拉图；0/false 关闭；1/true 强制（须 Key）
SYNTHETIC_FETCH_IMAGES=
SYNTHETIC_PEXELS_API_KEY=
