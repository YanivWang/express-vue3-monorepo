# 留空或未设置时，HTTP baseURL 为 ""，请求走相对路径 /api、/uploads。
VITE_API_BASE_URL=

# — Compose + 网关（浏览器入口为 GATEWAY_HOST_PORT）：相对路径经网关转发，通常保持上方为空即可。
# — 宿主本机只跑 Vite、后端仍在宿主监听 PORT（默认 3000）时：可显式设置后端 origin（须后端 CORS 放行）。
# VITE_API_BASE_URL=http://127.0.0.1:3000

# Vite 开发服务器转发 /api 等到后端的目标（默认 http://127.0.0.1:3000）。
# Docker compose 开发栈中会注入 http://rest-api:3000，指向容器内 Node。
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:3000

# Docker 网关模式下（浏览器入口为 GATEWAY_HOST_PORT，如 2026）HMR WebSocket 需使用该端口；一般由 compose 注入 VITE_DEV_HMR_CLIENT_PORT，不必手写。
# VITE_DEV_HMR_CLIENT_PORT=2026
