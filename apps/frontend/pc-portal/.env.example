# 留空或未设置时，HTTP baseURL 为 ""，请求走相对路径 /api、/uploads（由 Vite 开发代理转发到后端）。
VITE_API_BASE_URL=

# 直连后端时改为完整 origin，例如 http://127.0.0.1:3000（需后端 CORS 放行）。
# VITE_API_BASE_URL=http://127.0.0.1:3000

# Vite dev server 代理目标（默认 http://127.0.0.1:3000，与 apps/backend/rest-api 默认 PORT 一致）。
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:3000
